programa mi_programa;

vars
    x: entero;
    y: flotante;
    resultado: flotante;

inicio
{
    x = 10;
    y = 3.14;
    resultado = 1 + (2 - 2) * 4;
    escribe (x);

    mientras (x > 10) haz {
        escribe(x);
    };

    si (3 > 1) {
        escribe(123);
    } sino {
        escribe(321);
    };
}
fin